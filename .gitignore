# Dependencies (restored via npm install / pip install)
node_modules/
.venv/

# Build output
dist/

# Downloaded-on-demand heavy assets (never committed; the app fetches these)
piper/

# Runtime logs
*.log
@AutomationLog.txt
__pycache__/

# One-shot patch/install scaffolding (applied then retired — never committed)
_insert_*.js
_install_*.js
_patch_*.js

# External reference clones dropped into the tree (not Caryl code)
open-design/
